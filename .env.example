# Next.js next-auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# PostgreSQL / Prisma
DATABASE_URL=postgresql://postgres:password@host:5432/railway?schema=public

# OpenAI
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_RATE_LIMIT_PER_MINUTE=30
OPENAI_RATE_LIMIT_PER_DAY=100
DEFAULT_INBOX_THREAD_LIMIT=200

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-your-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-client-secret
