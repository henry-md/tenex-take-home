generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BucketKind {
  SYSTEM
  CUSTOM
}

enum IntegrationProvider {
  GMAIL
  GOOGLE_CALENDAR
}

enum IntegrationActionKind {
  EMAIL_ARCHIVE
  EMAIL_MARK_SPAM
  EMAIL_STAR
  EMAIL_UNSTAR
  EMAIL_TRASH
  EMAIL_APPLY_LABEL
  EMAIL_REMOVE_LABEL
  CALENDAR_CREATE_EVENT
  CALENDAR_UPDATE_EVENT
  CALENDAR_DELETE_EVENT
}

enum IntegrationActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
  EXPIRED
}

enum WorkspaceApprovalMode {
  SAFE
  BULK_EMAIL_ONLY
  DANGEROUS
}

enum OpenAIChatMessageRole {
  USER
  ASSISTANT
}

enum OpenAIRateLimitWindow {
  MINUTE
  DAY
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  image              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  buckets            Bucket[]
  inboxCaches        InboxClassificationCache[]
  emailThreads       EmailThread[]
  openAIChatMessages OpenAIChatMessage[]
}

model Bucket {
  id           String        @id @default(cuid())
  name         String
  kind         BucketKind    @default(CUSTOM)
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ownerId      String?
  owner        User?         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  emailThreads EmailThread[]

  @@unique([ownerId, name])
}

model EmailThread {
  id            String    @id @default(cuid())
  gmailThreadId String    @unique
  subject       String
  preview       String
  sender        String?
  lastMessageAt DateTime?
  archived      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  ownerId       String
  bucketId      String?
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bucket        Bucket?   @relation(fields: [bucketId], references: [id], onDelete: SetNull)
}

model IntegrationActionDraft {
  id              String                  @id @default(cuid())
  ownerEmail      String
  provider        IntegrationProvider
  kind            IntegrationActionKind
  status          IntegrationActionStatus @default(PENDING)
  title           String?
  summary         String
  targetId        String?
  beforeState     Json?
  afterState      Json?
  payload         Json
  executionResult Json?
  failureReason   String?
  expiresAt       DateTime
  approvedAt      DateTime?
  executedAt      DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([ownerEmail, status, createdAt])
}

model WorkspaceApprovalPreference {
  ownerEmail       String                @id
  mode             WorkspaceApprovalMode @default(SAFE)
  inboxThreadLimit Int?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model OpenAIChatMessage {
  id           String                @id @default(cuid())
  role         OpenAIChatMessageRole
  content      String
  toolCalls    Json?
  emailDisplay Json?
  emailResults Json?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  ownerId      String
  owner        User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
}

model OpenAIRateLimitBucket {
  ownerEmail  String
  windowType  OpenAIRateLimitWindow
  windowStart DateTime
  count       Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@id([ownerEmail, windowType, windowStart])
  @@index([windowType, windowStart])
}

model InboxClassificationCache {
  id           String   @id @default(cuid())
  cacheKey     String
  cacheKeyHash String
  payload      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, cacheKeyHash])
  @@index([ownerId, updatedAt])
}
